---
interface Props {
  appStoreUrl: string;
  playStoreUrl: string;
}
const { appStoreUrl, playStoreUrl } = Astro.props;
---

<footer class="footer">
  <div class="footer-main">
    <div class="footer-brand">
      <div class="logo">
        <img src={`${import.meta.env.BASE_URL}logoTopoQuizz.png`} alt="TopoQuizz Logo" class="logo-icon" />
        <span class="logo-text"><span class="brand-topo">Topo</span><span class="brand-quizz">Quizz</span></span>
      </div>
      <p>El quiz médico definitivo para estudiantes de medicina.</p>
      <small>Anatomía · Farmacología · y más próximamente</small>
    </div>
    <div class="footer-links">
      <div class="footer-col">
        <strong>APP</strong>
        <a href="#features">Características</a>
        <a href="#screenshots">Capturas</a>
        <a href="#como-funciona">Cómo funciona</a>
      </div>
      <div class="footer-col">
        <strong>DESCARGA</strong>
        <a href={appStoreUrl}>App Store</a>
        <a href={playStoreUrl}>Google Play</a>
      </div>
      <div class="footer-col">
        <strong>CONTACTO</strong>
        <a href="#">Soporte</a>
        <div class="footer-social">
          <a href="https://www.instagram.com/topoquizz?igsh=aTk4cmwxaDU4cWtw&utm_source=qr" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.tiktok.com/@topoquizz3?_r=1&_t=ZS-94dBZmCLxib" target="_blank" rel="noopener" aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.84a8.17 8.17 0 004.78 1.52V6.91a4.85 4.85 0 01-1.01-.22z"/></svg>
          </a>
          <a href="https://www.facebook.com/profile.php?id=61585292563440" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bottom-bar">
    <div class="footer-bottom">
      <span>© 2025 TopoQuizz. Todos los derechos reservados.</span>
      <div>
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
      </div>
    </div>
  </div>
</footer>
