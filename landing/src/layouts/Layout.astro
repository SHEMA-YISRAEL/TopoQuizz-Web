---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TopoQuizz — El Quiz Médico para Estudiantes',
  description = 'Domina la medicina con TopoQuizz. Preguntas de Anatomía, Farmacología y más. Practica, aprende y repasa.',
} = Astro.props;

const siteUrl = 'https://topoquizz.com';
const ogImage = `${siteUrl}/logoTopoQuizz.png`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "TopoQuizz",
      "url": siteUrl,
      "description": "App de quiz médico para estudiantes de medicina. Practica Anatomía, Farmacología, Bioquímica y más con preguntas cronometradas y seguimiento de progreso.",
      "applicationCategory": "EducationApplication",
      "operatingSystem": "iOS, Android",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "screenshot": `${siteUrl}/screenshots/quizz.png`,
      "featureList": [
        "Preguntas de Anatomía y Farmacología",
        "Modo cronómetro",
        "3 niveles de dificultad",
        "Progreso detallado",
        "Modo sin conexión"
      ],
      "inLanguage": "es",
      "image": ogImage
    },
    {
      "@type": "Organization",
      "name": "TopoQuizz",
      "url": siteUrl,
      "logo": ogImage,
      "sameAs": [
        "https://www.instagram.com/topoquizz",
        "https://www.tiktok.com/@topoquizz3",
        "https://www.facebook.com/profile.php?id=61585292563440"
      ]
    },
    {
      "@type": "WebSite",
      "name": "TopoQuizz",
      "url": siteUrl,
      "inLanguage": "es"
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="quiz médico, medicina, anatomía, farmacología, estudiantes de medicina, preguntas de medicina, app médica, examen médico" />
  <meta name="author" content="TopoQuizz" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={siteUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="TopoQuizz" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content="TopoQuizz — El Quiz Médico para Estudiantes" />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.png`} type="image/png" />
  <link rel="shortcut icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
</body>
</html>
